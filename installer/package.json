{
  "name": "isdp-installer",
  "version": "1.0.0",
  "description": "ISDP Windows Installer",
  "main": "./out/main/index.js",
  "author": "ISDP Team",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "package:launcher": "electron-builder --win --config electron-builder.launcher.yml",
    "package:setup": "electron-builder --win --config electron-builder.yml",
    "package": "npm run build && npm run package:launcher && npm run package:setup",
    "package:zip": "npm run package && node scripts/create-zip.js"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "antd": "^5.15.0",
    "mysql2": "^3.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "archiver": "^7.0.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}
