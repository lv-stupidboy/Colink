{
  "name": "colink-installer-tauri",
  "version": "1.0.0",
  "description": "Colink Windows Installer (Tauri)",
  "type": "module",
  "scripts": {
    "dev": "pnpm tauri dev",
    "dev:launcher": "pnpm tauri dev --config src-tauri/tauri.launcher.conf.json",
    "build": "pnpm tauri build",
    "build:launcher": "pnpm build:renderer && pnpm tauri build --config src-tauri/tauri.launcher.conf.json --no-bundle",
    "build:all": "pnpm build:renderer && pnpm build:launcher && pnpm build",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@codemirror/lang-yaml": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@uiw/react-codemirror": "^4.21.0",
    "antd": "^5.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
        "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}