server:
  port: 8080
  mode: debug

database:
  # 数据库类型: sqlite | mysql
  type: mysql

  # SQLite配置 (type=sqlite时生效)
  path: ./data/isdp.db

  # MySQL配置 (type=mysql时生效)
  mysql:
    host: "rm-bp1u503844l66n8g7no.mysql.rds.aliyuncs.com"
    port: 3306
    database: dev_xx  # 开发库，正式库用 product
    username: "isdp"
    password: "<密码>"  # 密码请通过团队内部渠道获取
    charset: utf8mb4
    max_open_conns: 10
    max_idle_conns: 5
    conn_max_lifetime: 300

redis:
  addr: localhost:6379
  password: ""
  db: 0

claude:
  path: claude
  default_model: claude-sonnet-4-6
  timeout: 30m

sandbox:
  port_range_start: 30000
  port_range_end: 40000
  default_cpu_limit: 2
  default_memory_limit: 4096
  network: isdp-network
  repos_dir: ./repos

agent:
  max_depth: 15
  max_retries: 3
  context_max_lines: 400

logging:
  level: info
  format: json

mcp:
  base_url: http://localhost:8080/api/v1/mcp
  token_ttl: 30m

# 认证配置
auth:
  # 访问邀请码，为空则不启用验证
  invite_code: ""

# Agent资产配置
agent_assets:
  # 资产存储基础路径，所有资产类型都在此目录下
  # 默认值: ./agent-assets
  base_path: ./agent-assets

# 技能配置
skill:
  # 技能使用次数统计更新间隔，默认 1h
  # 格式: "30m" (30分钟), "1h" (1小时), "2h30m" (2小时30分钟)
  use_count_update_interval: "1h"
  # 技能包上传最大大小，单位 MB，默认 5
  upload_max_size: 5

# 子代理配置
subagent:
  # 子代理文件上传最大大小，单位 MB，默认 2
  upload_max_size: 2

# 命令配置
command:
  # 命令文件上传最大大小，单位 MB，默认 2
  upload_max_size: 2

# 规约配置
rule:
  # 规约文件上传最大大小，单位 MB，默认 2
  upload_max_size: 2

# Agent配置相关
agent_config:
  # Agent配置输出目录
  # 默认值: ./agent-configs
  data_dir: ./agent-configs