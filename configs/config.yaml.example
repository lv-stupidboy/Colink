server:
  port: 26305
  mode: debug

# 数据目录配置
data:
  # 数据根目录，子目录: configs/, logs/, agent-assets/, agent-configs/, repos/
  base_path: ./data

database:
  # 数据库类型: sqlite | mysql
  type: sqlite

  # SQLite配置 (type=sqlite时生效)
  path: ./data/sqlite/colink.db

  # MySQL配置 (type=mysql时生效)
  mysql:
    host: "localhost"
    port: 3306
    database: colink
    username: "root"
    password: ""  # 请填写实际密码
    charset: utf8mb4
    max_open_conns: 10
    max_idle_conns: 5
    conn_max_lifetime: 300

redis:
  addr: localhost:6379
  password: ""
  db: 0

# Agent A2A 深度配置
agent:
  max_depth: 15  # A2A 链最大深度，防止无限递归

mcp:
  base_url: http://localhost:26305/api/v1/mcp
  token_ttl: 30m

# 认证配置
auth:
  # 访问邀请码，为空则不启用验证
  invite_code: ""

# Agent资产配置
agent_assets:
  base_path: ./data/agent-assets

# 技能配置
skill:
  # 更新间隔格式: "30m", "1h", "2h30m"
  use_count_update_interval: "1h"
  upload_max_size: 5

# 子代理配置
subagent:
  upload_max_size: 2

# 命令配置
command:
  upload_max_size: 2

# 规约配置
rule:
  upload_max_size: 2

# Agent配置池
agent_config:
   data_dir: ./data/agent-configs

# Multi-platform IM configuration
# 如需启用飞书等平台集成，请取消下方注释并填写对应配置
# 详见 docs/im-adapter-guide.md
im:
  platforms: []
  # platforms:
  #   # Feishu (Lark) platform
  #   - type: feishu
  #     enabled: true
  #     rate_limit_max: 20
  #     rate_limit_window: 60s
  #     max_retries: 3
  #     app_id: "your_app_id"
  #     app_secret: "your_app_secret"
  #     verification_token: ""
  #     encrypt_key: ""
  #     lark_cli_path: lark-cli
  #     default_project_id: ""
  #     event_mode: listener
  #
  #   # Slack platform
  #   - type: slack
  #     enabled: true
  #     rate_limit_max: 20
  #     rate_limit_window: 60s
  #     max_retries: 3
  #     bot_token: ""
  #     signing_secret: ""
  #
  #   # Discord platform
  #   - type: discord
  #     enabled: true
  #     rate_limit_max: 20
  #     rate_limit_window: 60s
  #     max_retries: 3
  #     bot_token: ""
  #     application_id: ""

# 数据上报配置 - 用于产品分析和内部统计
reporter:
  # 是否启用上报，默认开启
  enabled: true
  # 上报服务地址，如 https://stats.example.com/api/report
  endpoint: ""
  # 上报间隔，格式: "30m", "1h"
  interval: "30m"
  # 失败重试次数
  retry_times: 3
  # 重试间隔，格式: "1m", "30s"
  retry_interval: "1m"